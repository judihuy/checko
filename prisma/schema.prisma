// Checko — Prisma Schema
// Database: MySQL
// Checkos-System (Coin-basiert, KEIN Abo-Modell)
// Plus NextAuth tables: Account, Session, VerificationToken

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== AUTH (NextAuth) ====================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==================== CORE MODELS ====================

model User {
  id                    String               @id @default(cuid())
  email                 String               @unique
  emailVerified         DateTime?
  isEmailVerified       Boolean              @default(false)
  verificationToken     String?              @unique
  name                  String?
  image                 String?
  password              String?
  role                  String               @default("user")
  resetToken            String?              @unique
  resetTokenExpiresAt   DateTime?
  checkosBalance        Int                  @default(0)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  accounts              Account[]
  sessions              Session[]
  checkoTransactions    CheckoTransaction[]
  checkoPurchases       CheckoPurchase[]
  searches              PreisradarSearch[]
}

model Module {
  id            String         @id @default(cuid())
  slug          String         @unique
  name          String
  description   String         @db.Text
  priceMonthly  Int
  icon          String?
  isActive      Boolean        @default(false)
  sortOrder     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// ==================== CHECKOS (Coin-System) ====================

model CheckoTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Int      // positiv = Gutschrift, negativ = Verbrauch
  type        String   // "purchase" | "usage" | "gift" | "referral" | "welcome" | "wheel" | "daily_wheel"
  description String?
  moduleSlug  String?  // welches Modul wurde genutzt
  qualityTier String?  // "standard" | "premium" | "pro"
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CheckoPurchase {
  id              String   @id @default(cuid())
  userId          String
  amount          Int      // Anzahl Checkos
  priceCHF        Int      // Preis in Rappen
  stripePaymentId String?  @unique
  status          String   @default("completed")
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ==================== ADMIN & CONTENT ====================

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  target    String?
  details   String?  @db.Text
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
}

model ContentBlock {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String?
  content   String   @db.LongText
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model PromoCode {
  id              String    @id @default(cuid())
  code            String    @unique
  discountPercent Int
  maxUses         Int?
  usedCount       Int       @default(0)
  validUntil      DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
}

// ==================== PREISRADAR ====================

model PreisradarSearch {
  id        String             @id @default(cuid())
  userId    String
  query     String
  maxPrice  Int?
  minPrice  Int?
  platforms String
  isActive  Boolean            @default(true)
  alerts    PreisradarAlert[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  user      User               @relation(fields: [userId], references: [id])

  @@index([userId])
}

model PreisradarAlert {
  id         String           @id @default(cuid())
  searchId   String
  title      String
  price      Int
  platform   String
  url        String
  imageUrl   String?
  priceScore String?
  aiAnalysis String?          @db.Text
  isScam     Boolean          @default(false)
  isSeen     Boolean          @default(false)
  createdAt  DateTime         @default(now())
  search     PreisradarSearch @relation(fields: [searchId], references: [id])

  @@index([searchId])
}
