// Checko — Prisma Schema
// Database: MySQL
// Checkos-System (Coin-basiert, KEIN Abo-Modell)
// Plus NextAuth tables: Account, Session, VerificationToken

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== AUTH (NextAuth) ====================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==================== CORE MODELS ====================

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  emailVerified       DateTime?
  isEmailVerified     Boolean   @default(false)
  verificationToken   String?   @unique
  name                String?
  image               String?
  password            String?
  role                String    @default("user")
  resetToken          String?   @unique
  resetTokenExpiresAt DateTime?
  checkosBalance      Int       @default(0)
  referralCode        String?   @unique
  referredBy          String?
  isSuspended                Boolean   @default(false)
  suspendReason              String?
  registrationNumber         Int?
  bonusSpins                 Int       @default(0)
  bonusSpinsNoSpendRequired  Boolean   @default(false)
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  accounts                Account[]
  sessions                Session[]
  checkoTransactions      CheckoTransaction[]
  checkoPurchases         CheckoPurchase[]
  searches                PreisradarSearch[]
  referralsMade           Referral[]               @relation("ReferralsMade")
  referralsReceived       Referral[]               @relation("ReferralsReceived")
  wheelSpins              WheelSpin[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  savedAlerts             SavedAlert[]
  pushSubscriptions       PushSubscription[]
}

model Module {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  description  String   @db.Text
  priceMonthly Int
  icon         String?
  isActive     Boolean  @default(false)
  status       String   @default("coming_soon") // active, coming_soon, beta, maintenance
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  waitlist ModuleWaitlist[]
}

model ModuleWaitlist {
  id        String   @id @default(cuid())
  moduleId  String
  email     String
  createdAt DateTime @default(now())

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([moduleId, email])
  @@index([moduleId])
}

// ==================== CHECKOS (Coin-System) ====================

model CheckoTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Int // positiv = Gutschrift, negativ = Verbrauch
  type        String // "purchase" | "usage" | "gift" | "referral" | "welcome" | "wheel" | "daily_wheel" | "affiliate"
  description String?
  moduleSlug  String? // welches Modul wurde genutzt
  qualityTier String? // "standard" | "premium" | "pro"
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CheckoPurchase {
  id              String   @id @default(cuid())
  userId          String
  amount          Int // Anzahl Checkos
  priceCHF        Int // Preis in Rappen
  stripePaymentId String?  @unique
  status          String   @default("completed")
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ==================== REFERRAL (Empfehlungssystem) ====================

model Referral {
  id            String   @id @default(cuid())
  referrerId    String
  referredId    String
  checkosEarned Int      @default(0)
  createdAt     DateTime @default(now())

  referrer User @relation("ReferralsMade", fields: [referrerId], references: [id], onDelete: Cascade)
  referred User @relation("ReferralsReceived", fields: [referredId], references: [id], onDelete: Cascade)

  @@unique([referredId])
  @@index([referrerId])
}

// ==================== GLÜCKSRAD (Wheel Spins) ====================

model WheelSpin {
  id        String   @id @default(cuid())
  userId    String
  type      String // "registration" | "daily"
  amount    Int
  ipAddress String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([ipAddress])
  @@index([type])
}

// ==================== ADMIN & CONTENT ====================

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  target    String?
  details   String?  @db.Text
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
}

model ContentBlock {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String?
  content   String   @db.LongText
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model PromoCode {
  id              String    @id @default(cuid())
  code            String    @unique
  discountPercent Int
  maxUses         Int?
  usedCount       Int       @default(0)
  validUntil      DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
}

// ==================== BENACHRICHTIGUNGEN ====================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // "preisradar_alert", "welcome", "system", "referral"
  category  String   @default("system") // "wheel", "preisradar", "checkos", "system"
  title     String   @db.Text
  message   String   @db.Text
  link      String?  @db.Text // Optional: Link zum Treffer/Seite
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

model NotificationPreference {
  id      String  @id @default(cuid())
  userId  String
  channel String // "email", "inapp", "telegram", "push", "whatsapp", "sms"
  enabled Boolean @default(true)
  config  String? @db.Text // JSON config (z.B. Telegram Chat ID)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel])
}

// ==================== SYSTEM SETTINGS ====================

model SystemSettings {
  id    String @id @default("default")
  key   String @unique
  value String @db.Text

  @@map("system_settings")
}

// ==================== PREISRADAR ====================

model PreisradarSearch {
  id             String            @id @default(cuid())
  userId         String
  query          String
  maxPrice       Int?
  minPrice       Int?
  platforms      String // Komma-getrennt: "tutti,ricardo,ebay-ka"
  category       String?           // Hauptkategorie: Fahrzeuge, Elektronik, Immobilien, etc.
  subcategory    String?           // Unterkategorie: Autos, Motorräder, Smartphones, etc.
  condition      String?           // Zustand: Alle, Neu, Gebraucht

  // === Fahrzeug-Felder (Auto + Motorrad) ===
  vehicleMake        String?       // Marke: BMW, Audi, Honda, etc.
  vehicleModel       String?       // Modell: M3, A4, CBR600, etc.
  yearFrom           Int?          // Baujahr von
  yearTo             Int?          // Baujahr bis
  kmFrom             Int?          // Kilometer von
  kmTo               Int?          // Kilometer bis
  fuelType           String?       // Treibstoff: benzin, diesel, elektro, hybrid
  transmission       String?       // Getriebe: manuell, automat
  // Motorrad-spezifisch
  engineSizeCcm      Int?          // Hubraum in ccm
  motorcycleType     String?       // Typ: naked, sport, chopper, enduro, touring, scooter

  // === Immobilien-Felder ===
  propertyType       String?       // Typ: wohnung, haus, grundstueck, gewerbe
  propertyOffer      String?       // Angebot: miete, kauf
  rooms              Int?          // Zimmer (min)
  areaM2             Int?          // Fläche m² (min)
  location           String?       // Ort / PLZ

  // === Möbel-Felder ===
  furnitureType      String?       // Typ: sofa, tisch, schrank, bett, etc.

  isActive       Boolean           @default(true)
  isDraft        Boolean           @default(false)
  duration       String            @default("1d") // "1d" | "1w" | "1m"
  qualityTier    String            @default("standard") // "standard" | "premium" | "pro"
  interval       Int               @default(30) // Minuten: 1440=Standard(24h), 720=Premium(12h), 5=Pro
  expiresAt      DateTime?
  checkosCharged Int               @default(0)
  lastScrapedAt  DateTime?
  alerts         PreisradarAlert[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@index([expiresAt])
}

model PreisradarAlert {
  id         String           @id @default(cuid())
  title      String           @db.Text
  price      Int
  platform   String           @db.Text
  url        String           @db.Text
  imageUrl   String?          @db.Text
  priceScore String?          @db.Text
  aiAnalysis String?          @db.Text
  isScam         Boolean          @default(false)
  isSeen         Boolean          @default(false)
  detailAnalysis String?          @db.LongText
  searchId   String
  createdAt  DateTime         @default(now())
  search     PreisradarSearch @relation(fields: [searchId], references: [id], onDelete: Cascade)
  savedBy    SavedAlert[]

  @@index([searchId])
  @@index([createdAt])
}

// ==================== FAVORITEN / GESPEICHERTE ALERTS ====================

model SavedAlert {
  id         String   @id @default(cuid())
  userId     String
  alertId    String
  isFavorite Boolean  @default(false) // false = gespeichert, true = Favorit
  note       String?  @db.Text        // optionale Notiz vom User
  createdAt  DateTime @default(now())

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  alert PreisradarAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@unique([userId, alertId])
  @@index([userId])
  @@index([alertId])
}

// ==================== PUSH SUBSCRIPTIONS ====================

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique @db.VarChar(512)
  keys      String   @db.Text // JSON: { p256dh, auth }
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
